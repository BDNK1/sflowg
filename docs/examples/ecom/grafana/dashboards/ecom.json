{
  "title": "Ecommerce API",
  "uid": "ecom-api",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["ecom", "sflowg"],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Order Totals",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Orders Created",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "sum(ecom_orders_created_total)",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Payments Initiated",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "sum(ecom_payment_initiated_total)",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Orders Canceled",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "sum(ecom_orders_canceled_total)",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Payment Errors",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "sum(ecom_payment_errors_total)",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 6,
      "type": "row",
      "title": "Activity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Order Activity (rate/5m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "rate(ecom_orders_created_total[5m])",
          "legendFormat": "created"
        },
        {
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "rate(ecom_payment_initiated_total[5m])",
          "legendFormat": "payment initiated"
        },
        {
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "rate(ecom_orders_canceled_total[5m])",
          "legendFormat": "canceled"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Payment Error Rate (rate/5m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "rate(ecom_payment_errors_total[5m])",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "Order Amounts",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Order Amount Percentiles (cents)",
      "description": "p50 / p90 / p99 of ecom_order_amount_cents histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 0 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(ecom_order_amount_cents_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "histogram_quantile(0.90, rate(ecom_order_amount_cents_bucket[5m]))",
          "legendFormat": "p90"
        },
        {
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(ecom_order_amount_cents_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Order Amount Throughput (orders/5m)",
      "description": "Number of orders with amounts recorded per 5-minute window",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "rate(ecom_order_amount_cents_count[5m])",
          "legendFormat": "orders/s"
        }
      ]
    }
  ]
}

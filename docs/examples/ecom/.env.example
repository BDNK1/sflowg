# Database connection
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ecommerce?sslmode=disable

# Optional settings
PORT=8080
HTTP_TIMEOUT=10s
STRIPE_INTEGRATION_URL=http://localhost:8090

# Observability
# Set TRACING_ENABLED=true and point OTEL_EXPORTER_OTLP_ENDPOINT at the collector
# to export traces and metrics (requires docker-compose observability stack).
TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
